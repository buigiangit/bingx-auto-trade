# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# BingX
BINGX_API_KEY=your_bingx_api_key
BINGX_SECRET_KEY=your_bingx_secret_key
BINGX_ENV=prod-vst

# Market
SYMBOL=BTC-USDT
INTERVAL=15m
LIMIT=240

# Risk
ACCOUNT_EQUITY_USDT=1000
RISK_PER_TRADE_PCT=0.3
MAX_LEVERAGE=2
MIN_CONFIDENCE=75
MAX_SPREAD_PCT=0.08
MAX_ABS_FUNDING_RATE=0.0008
MIN_RR=1.2
MAX_NOTIONAL_USDT=20
ORDER_MARGIN_USDT=10

# Execution
EXECUTION_MODE=SIGNAL_ONLY
CHECK_INTERVAL_SECONDS=300

# Position
ALLOW_ADD_POSITION=false

# DCA
ALLOW_DCA=false
DCA_TRIGGER_ROE_PCT=-20
MAX_DCA_COUNT=1
DCA_MARGIN_USDT=5
MIN_SECONDS_BETWEEN_DCA=1800